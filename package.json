{
  "name": "sdlc-harness",
  "version": "1.5.0",
  "description": "Multi-agent SDLC harness with knowledge graph, quality gates, and swappable LLM backends",
  "type": "module",
  "license": "MIT",
  "author": "madhavmadupu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madhavmadupu/sdlc-harness.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "sdlc",
    "multi-agent",
    "ai",
    "software-development",
    "knowledge-graph",
    "opencode"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "sdlc-harness": "dist/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "publish:npm": "npm publish --registry=https://registry.npmjs.org --access public",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com"
  },
  "dependencies": {
    "@unblessed/node": "^1.0.0-alpha.23",
    "better-sqlite3": "^11.0.0",
    "opencode-ai": "^1.15.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
